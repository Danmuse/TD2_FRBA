	MOV  R4,#1						// Modifico el registro. Guardo el valor 1 en la variable
 8000206:	f04f 0401 	mov.w	r4, #1
	POP  {R4}						// Opero sobre la pila. Restauro el registro
 800020a:	bc10      	pop	{r4}
	BX   LR							// Retorna. Dirección apuntada al registro
 800020c:	4770      	bx	lr

