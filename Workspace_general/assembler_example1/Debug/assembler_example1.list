    SUBS R1,R1,#1    				// SUBS ya actualiza el flag Z
 800022a:	3901      	subs	r1, #1
    // Eliminamos CMP R1, #0 por ser redundante

	BNE  FST_RECURSIVE_LOOP			// Repite el lazo de acuerdo al resultado de CMP
